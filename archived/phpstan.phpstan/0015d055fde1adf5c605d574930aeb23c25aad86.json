{
    "manifests": {
        "phpstan/phpstan": {
            "manifest": {
                "composer-commands": {
                    "analyse": "phpstan analyse"
                },
                "copy-from-recipe": {
                    "phpstan.dist.neon": "phpstan.dist.neon",
                    "tests/object-manager.php": "tests/object-manager.php"
                },
                "gitignore": [
                    "/phpstan.neon"
                ]
            },
            "files": {
                "phpstan.dist.neon": {
                    "contents": [
                        "# Comment r\u00e9g\u00e9n\u00e9rer la baseline ?",
                        "# $ composer install (id\u00e9alement composer update)",
                        "# $ composer run analyse",
                        "# Corriger toutes les erreurs jusqu'\u00e0 avoir \"[OK] No errors\"",
                        "# $ composer exec phpstan -- analyse --generate-baseline",
                        "# V\u00e9rifier le diff Git : il ne doit normalement avoir aucune nouvelle erreur ignor\u00e9e (sauf si c'est une erreur existante qui a chang\u00e9)",
                        "# Au besoin, corriger les erreurs et reprendre ce guide au d\u00e9but",
                        "",
                        "# D\u00e9commenter pour utiliser la baseline",
                        "# includes:",
                        "#     - phpstan-baseline.neon",
                        "",
                        "parameters:",
                        "    level: 10 # Ne pas abaisser ce niveau sur des projets r\u00e9cents, utiliser la baseline si n\u00e9cessaire : https://phpstan.org/user-guide/baseline",
                        "    paths:",
                        "        - migrations",
                        "        - src",
                        "        - tests",
                        "    excludePaths:",
                        "        - tests/application-loader.php",
                        "        - tests/bootstrap.php",
                        "        - tests/object-manager.php",
                        "#     reportUnmatchedIgnoredErrors: false # D\u00e9commenter pour utiliser la baseline",
                        "    tmpDir: var/phpstan",
                        "",
                        "    doctrine:",
                        "        objectManagerLoader: tests/object-manager.php",
                        "",
                        "    symfony:",
                        "        consoleApplicationLoader: tests/console-application.php",
                        "        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml",
                        ""
                    ],
                    "executable": false
                },
                "tests/application-loader.php": {
                    "contents": [
                        "<?php",
                        "",
                        "use App\\Kernel;",
                        "use Symfony\\Bundle\\FrameworkBundle\\Console\\Application;",
                        "use Symfony\\Component\\Dotenv\\Dotenv;",
                        "",
                        "require __DIR__.'/../vendor/autoload.php';",
                        "",
                        "(new Dotenv())->bootEnv(__DIR__.'/../.env');",
                        "",
                        "$kernel = new Kernel($_SERVER['APP_ENV'], (bool) $_SERVER['APP_DEBUG']);",
                        "",
                        "return new Application($kernel);",
                        ""
                    ],
                    "executable": false
                },
                "tests/object-manager.php": {
                    "contents": [
                        "<?php",
                        "",
                        "use App\\Kernel;",
                        "use Symfony\\Component\\Dotenv\\Dotenv;",
                        "",
                        "require __DIR__.'/../vendor/autoload.php';",
                        "",
                        "(new Dotenv())->bootEnv(__DIR__.'/../.env');",
                        "",
                        "$kernel = new Kernel($_SERVER['APP_ENV'], (bool) $_SERVER['APP_DEBUG']);",
                        "$kernel->boot();",
                        "",
                        "return $kernel->getContainer()->get('doctrine')->getManager();",
                        ""
                    ],
                    "executable": false
                }
            },
            "ref": "0015d055fde1adf5c605d574930aeb23c25aad86"
        }
    }
}
