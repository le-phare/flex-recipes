{
    "aliases": ["cs-fixer", "php-cs-fixer"],
    "composer-commands": {
        "lint:php": "@lint:php:fix --dry-run",
        "lint:php:fix": "php-cs-fixer fix"
    },
    "copy-from-recipe": {
        ".php-cs-fixer.dist.php": ".php-cs-fixer.dist.php"
    },
    "gitignore": [
        "/.php-cs-fixer.php"
    ]
}
